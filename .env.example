# Supabase 配置
# 从 Supabase 控制台获取：https://app.supabase.com/project/your-project/settings/api
NUXT_SUPABASE_URL=https://your-project.supabase.co
NUXT_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...（service_role key，仅服务端）

# 前端 Supabase 配置（用于直接上传，绕过 Vercel 限制）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...（anon key，前端可见）

# 认证密钥（用于 nuxt-auth-utils）
NUXT_AUTH_SECRET=your-random-secret-here

# 上传文件大小限制（默认 100MB）
NUXT_PUBLIC_UPLOAD_MAX_SIZE=104857600
